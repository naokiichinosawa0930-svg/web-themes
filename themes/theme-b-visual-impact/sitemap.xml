<?xml version="1.0" encoding="UTF-8"?>
<!--
  sitemap.xml - サイトマップ（検索エンジンにページ一覧を伝えるファイル）
  ★ すべての <loc> の "https://example.com" を実際のサイトURLに変更してください
  ★ <lastmod> はページを更新した日付に変更してください（YYYY-MM-DD形式）
  ★ Googleサーチコンソールでサイトマップを登録すると検索インデックスが早まります
-->
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">

  <!-- トップページ（最も重要: priority=1.0） -->
  <url>
    <loc>https://example.com/</loc>
    <lastmod>2024-04-01</lastmod>
    <changefreq>weekly</changefreq>
    <priority>1.0</priority>
  </url>

  <!-- 当店について -->
  <url>
    <loc>https://example.com/about.html</loc>
    <lastmod>2024-04-01</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.8</priority>
  </url>

  <!-- コースメニュー -->
  <url>
    <loc>https://example.com/service.html</loc>
    <lastmod>2024-04-01</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.9</priority>
  </url>

  <!-- ギャラリー -->
  <url>
    <loc>https://example.com/works.html</loc>
    <lastmod>2024-04-01</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.7</priority>
  </url>

  <!-- お知らせ -->
  <url>
    <loc>https://example.com/news.html</loc>
    <lastmod>2024-12-20</lastmod>
    <changefreq>weekly</changefreq>
    <priority>0.7</priority>
  </url>

  <!-- ご予約・お問い合わせ -->
  <url>
    <loc>https://example.com/contact.html</loc>
    <lastmod>2024-04-01</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.9</priority>
  </url>

</urlset>
