<?xml version="1.0" encoding="UTF-8"?>
<!--
  sitemap.xml - サイトマップ
  検索エンジンにサイトのページ一覧を伝えるファイルです
  ============================================
  すべての https://example.com を実際のサイトURLに変更してください
  lastmod の日付はそのページを最後に更新した日付を入力してください
  ============================================
-->
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">

  <!-- トップページ -->
  <url>
    <loc>https://example.com/</loc>
    <lastmod>2026-04-01</lastmod>
    <changefreq>monthly</changefreq>
    <priority>1.0</priority>
  </url>

  <!-- 会社概要 -->
  <url>
    <loc>https://example.com/about.html</loc>
    <lastmod>2026-04-01</lastmod>
    <changefreq>yearly</changefreq>
    <priority>0.8</priority>
  </url>

  <!-- サービス紹介 -->
  <url>
    <loc>https://example.com/service.html</loc>
    <lastmod>2026-04-01</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.9</priority>
  </url>

  <!-- 導入実績 -->
  <url>
    <loc>https://example.com/works.html</loc>
    <lastmod>2026-04-01</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.7</priority>
  </url>

  <!-- お知らせ -->
  <url>
    <loc>https://example.com/news.html</loc>
    <lastmod>2026-04-15</lastmod>
    <changefreq>weekly</changefreq>
    <priority>0.6</priority>
  </url>

  <!-- お問い合わせ -->
  <url>
    <loc>https://example.com/contact.html</loc>
    <lastmod>2026-04-01</lastmod>
    <changefreq>yearly</changefreq>
    <priority>0.8</priority>
  </url>

  <!-- プライバシーポリシー -->
  <url>
    <loc>https://example.com/privacy.html</loc>
    <lastmod>2026-04-01</lastmod>
    <changefreq>yearly</changefreq>
    <priority>0.3</priority>
  </url>

</urlset>
